class Solution {
public:
    bool validPath(int n, vector<vector<int>>& edges, int source, int destination) {
        
        vector<vector<int>> graph(n);

        for(auto& e : edges)
        {
            int a = e[0];
            int b = e[1];

            graph[a].push_back(b);
            graph[b].push_back(a);
        }

        vector<bool> visited(n, false);

        return dfs(graph, visited, source, destination);
    }

    bool dfs(vector<vector<int>>& graph, vector<bool>& visited, int cur, int destination)
    {
        if(cur == destination)
            return true;

        visited[cur] = true;

        for(int next : graph[cur])
        {
            if(!visited[next])
            {
                if(dfs(graph, visited, next, destination))
                    return true;
            }
        }

        return false;
    }
};

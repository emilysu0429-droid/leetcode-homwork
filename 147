class Solution {
public:
    ListNode* insertionSortList(ListNode* head) {
        ListNode dummy(0);
        ListNode* current = head;

        while (current != NULL) {
            ListNode* prev = &dummy;

            // 找插入位置
            while (prev->next != NULL && prev->next->val < current->val) {
                prev = prev->next;
            }

            // 插入
            ListNode* nextTemp = current->next;
            current->next = prev->next;
            prev->next = current;

            current = nextTemp;
        }

        return dummy.next;
    }
};
